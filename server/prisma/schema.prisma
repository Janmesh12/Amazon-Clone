generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  SELLER
  USER
}

// ─── USER ─────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  mobile    String?
  password  String
  avatarUrl String?
  role      RoleType     @default(USER)
  roleId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts           Cart[]
  wishlists       Wishlist[]
  orders          Order[]
  products        Product[]   // Products listed by this seller
  accessRequests  AccessRequest[] 
  supportTickets  SupportTicket[]
  auditLogs       AuditLog[]
  dynamicRole     DynamicRole? @relation("UserRole", fields: [roleId], references: [id])
}

// ─── PRODUCT ──────────────────────────
model Product { 
  id          Int         @id @default(autoincrement())
  name        String
  image_url   String
  category    String
  price       Decimal     @default(0) @db.Decimal(10, 2)
  description String?
  features    String?     // Comma-separated list for dynamic bullet points
  rating      Float       @default(4.5)
  numReviews  Int         @default(100)
  sellerId    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?

  seller        User?       @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  cartItems     Cart[]
  orderItems    OrderItem[]
  wishlistItems Wishlist[]
}

// ─── CART ─────────────────────────────
model Cart {
  id         Int      @id @default(autoincrement())
  userId     Int
  product_id Int
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

// ─── WISHLIST ─────────────────────────
model Wishlist {
  id         Int      @id @default(autoincrement())
  userId     Int
  product_id Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

// ─── ORDER ────────────────────────────
model Order {
  id        Int      @id @default(autoincrement())
  userId    Int
  total     Decimal  @db.Decimal(10, 2)
  status    String   @default("Confirmed")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Payment Tracking
  razorpay_order_id   String? @unique
  razorpay_payment_id String?
  razorpay_signature  String?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]
}

// ─── ORDER ITEM ───────────────────────
model OrderItem {
  id         Int      @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  price      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

// ─── ACCESS REQUEST ──────────────────
enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AccessRequest {
  id            Int           @id @default(autoincrement())
  userId        Int
  requestedRole RoleType
  status        RequestStatus @default(PENDING)
  reason        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ROLE MANAGEMENT (DYNAMIC ROLES) ──
model Module {
  id   Int    @id @default(autoincrement())
  name String @unique

  permissions Permission[]
}

model Permission {
  id       Int  @id @default(autoincrement())
  roleId   Int
  moduleId Int

  view   Boolean @default(false)
  create Boolean @default(false)
  update Boolean @default(false)
  delete Boolean @default(false)

  role   DynamicRole @relation(fields: [roleId], references: [id])
  module Module      @relation(fields: [moduleId], references: [id])

  @@unique([roleId, moduleId])
}

model DynamicRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions Permission[]
  users       User[] @relation("UserRole")
}
// ─── AMENDING USER FOR DYNAMIC ROLE ───
// To keep things compatible, I'll add a link to DynamicRole
// and keep the RoleType as a "Base Role" for legacy logic.
// But for true dynamic roles, I'll use this.

// ─── SUPPORT TICKETS ─────────────────
model SupportTicket {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // e.g., "Refund Request", "Missing Order"
  message     String
  status      String   @default("OPEN") // e.g., "OPEN", "RESOLVED", "CLOSED"
  response    String?  // Staff's reply to user
  resolvedById Int?    // Staff ID who resolved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String   // e.g., "ROLE_CHANGE", "TICKET_RESOLVED", "PRODUCT_DELETED"
  details   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}