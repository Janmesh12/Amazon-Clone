		{
			"name": "2. Role Management",
			"item": [
				{
					"name": "List All Dynamic Roles",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/roles",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"roles"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update Analyst Permissions",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"permissions\": [\n        {\n            \"moduleId\": 1,\n            \"view\": true,\n            \"create\": false,\n            \"update\": false,\n            \"delete\": false\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/roles/3/permissions",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"roles",
								"3",
								"permissions"
							],
                            "description": "Role ID 3 is usually the Analyst role. This sets Products (ID 1) to View-Only."
						}
					},
					"response": []
				}
			]
		},
